EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# The Supabase SERVICE ROLE key and the ANTHROPIC_API_KEY are NEVER put
# in this file — they belong only in Supabase Edge Function environment
# variables, set via `supabase secrets set`. If either ever needs to be
# referenced locally for testing an Edge Function, it goes in
# supabase/functions/.env, which is also gitignored.
