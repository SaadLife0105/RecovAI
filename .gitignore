# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local
!.env.example
evaluation/.env

# Firebase service account key (FCM V1 push notifications) — sensitive,
# grants admin-level Firebase access. Uploaded directly to EAS via
# `eas credentials`, never committed. google-services.json is NOT ignored —
# that one only contains public-facing project identifiers and is safe to
# commit (Firebase's own docs confirm this).
*firebase-adminsdk*.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

#misc
docs/misc

# diagnostic dumps (adb bugreport captures, not project data)
crash_log.txt
*.txt.bak
