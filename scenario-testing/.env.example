# Copy to .env.local and fill in. `.env*.local` is already covered by the root
# .gitignore, so .env.local will never be committed — verified with
# `git check-ignore` before this file was created. Never commit real secrets.

# Supabase project
SUPABASE_URL=https://<project-ref>.supabase.co

# Anon key — used only to sign in AS the test patient, to get a genuine patient
# JWT (risk-agent rejects the service role: it verifies auth.getUser()).
SUPABASE_ANON_KEY=

# Service-role key — used for seeding/reset only. It bypasses RLS, which is
# what makes the harness able to write check-ins and clear
# flagged_for_urgent_review (0011's trigger blocks a patient client from that).
# LOCAL ONLY. Never goes near the app bundle.
SUPABASE_SERVICE_ROLE_KEY=

# No ANTHROPIC_API_KEY here: this harness never calls Anthropic directly. The
# agent's own key lives in Supabase's secrets store, server-side.
