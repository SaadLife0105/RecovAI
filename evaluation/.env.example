# Copy to .env and fill in. .env is gitignored (the bare `.env` pattern in the
# root .gitignore matches evaluation/.env too). Never commit real secrets.

# Supabase project (anon key only — same key the app bundle uses)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# An existing eval patient account (username + password, as created by a doctor)
EVAL_PATIENT_USERNAME=eval_patient
EVAL_PATIENT_PASSWORD=your-eval-patient-password

# Anthropic key for the DeepEval judge model (Claude Sonnet). LOCAL to this
# script only — separate from and unrelated to the Supabase Edge Function
# secret of the same name.
ANTHROPIC_API_KEY=sk-ant-your-key
